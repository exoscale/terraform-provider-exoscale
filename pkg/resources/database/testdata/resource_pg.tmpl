resource "exoscale_dbaas" {{ .ResourceName }} {
  name = "{{ .Name }}"
  type = "pg"
  plan = "{{ .Plan }}"
  zone = "{{ .Zone }}"

  {{- if .DependsOn }}
  depends_on = [
  {{- range $k, $v := .DependsOn }}
    {{ $v }},
  {{- end }}
  ]
  {{- end }}

  {{- if .MaintenanceDow }}
  maintenance_dow = "{{ .MaintenanceDow }}"
  {{- end }}

  {{- if .MaintenanceTime }}
  maintenance_time = "{{ .MaintenanceTime }}"
  {{- end }}
  termination_protection = {{- .TerminationProtection }}
  pg = {
    {{- if .AdminPassword }}
    admin_password = "{{ .AdminPassword }}"
    {{- end }}

    {{- if .AdminUsername }}
    admin_username = "{{ .AdminUsername }}"
    {{- end }}

    {{- if .BackupSchedule }}
    backup_schedule = "{{ .BackupSchedule }}"
    {{- end }}

    {{- if .IpFilter }}
    ip_filter = [
    {{- range $k,$v := .IpFilter }}
       "{{ $v }}",
    {{- end }}
    ]
    {{- end }}

    {{- if .PgSettings }}
    pg_settings = {{ .PgSettings }}
    {{- end }}

    {{- if .PgbouncerSettings }}
    pgbouncer_settings = {{ .PgbouncerSettings }}
    {{- end }}

    {{- if .PglookoutSettings }}
    pglookout_settings = {{ .PglookoutSettings }}
    {{- end }}

    {{- if .Version }}
    version = "{{ .Version }}"
    {{- end }}

    {{- if .Integrations }}
    integrations = [
    {{- range $k, $v := .Integrations }}
      {
        type           = "{{ $v.Type }}"
        source_service = {{ $v.SourceService }}
      },
    {{- end }}
    ]
    {{- end }}
  }
}
